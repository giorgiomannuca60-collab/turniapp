PORT=3000

# Anno di riferimento per interpretare i file settimanali senza anno nel titolo.
# AGGIORNA QUESTO ogni anno nuovo su Railway → Settings → Variables
ANNO_RIFERIMENTO=2026

# Data minima fino a cui calcolare i turni passati a ritroso (inizio anno corrente)
DATA_MINIMA_PASSATO=2026-01-01

# Credenziali Gmail OAuth (da Google Cloud Console → Credentials)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# URL pubblico dell'app Railway (senza slash finale)
# es. https://turniapp-production-xxxx.up.railway.app
APP_BASE_URL=
