PORT=3000

# Credenziali Gmail OAuth (da Google Cloud Console → Credentials)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# URL pubblico dell'app (il link Railway, es. https://turniapp-production-xxxx.up.railway.app)
# Usato per costruire il redirect URI di Google: deve combaciare ESATTAMENTE
# con quello inserito in "Authorized redirect URIs" su Google Cloud Console
# (con in fondo aggiunto /auth/google/callback)
APP_BASE_URL=
